<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/dragHandle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿"
            android:textColor="#9AA0A6"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxWidth="160dp"
            android:singleLine="true"
            android:text="매크로"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxWidth="200dp"
        android:text="준비됨"
        android:textColor="#4FC3F7"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="▶ 시작"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="✎ 수정"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/btnCapture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="📷"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="✕ 닫기"
            android:textColor="#FF8A80" />
    </LinearLayout>

    <!-- 앱 위에서 바로 단계를 만드는 빌드 컨트롤 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnAddTap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="＋탭 위치"
            android:textColor="#A5D6A7"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnAddFind"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="＋이미지 찾아 탭"
            android:textColor="#A5D6A7"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnAddJump"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="＋조건 이동"
            android:textColor="#A5D6A7"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 실행 옵션: 간격 / 반복(무한=감시·오토마우스) / 자동중지 / 시작지연(예약) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnInterval"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:text="⏱ 0.3s"
            android:textColor="#FFE082" />

        <TextView
            android:id="@+id/btnRepeat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:text="🔁 1회"
            android:textColor="#FFE082" />

        <TextView
            android:id="@+id/btnTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:text="⏰ 끔"
            android:textColor="#FFE082" />

        <TextView
            android:id="@+id/btnStartDelay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:text="▷ 즉시"
            android:textColor="#FFE082" />
    </LinearLayout>

    <!-- 단계 편집 패널 (✎ 수정 시 펼침) — 앱으로 나가지 않고 오버레이 안에서 편집 -->
    <LinearLayout
        android:id="@+id/editPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="6dp"
            android:background="#33FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtStepHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="단계 0개"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnClearSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_pill"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="전체삭제"
                android:textColor="#FF8A80"
                android:textSize="12sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/editScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/stepList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>
